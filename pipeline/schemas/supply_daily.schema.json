{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://0xfanbase.github.io/Bitcoin-Engine-Room/schemas/supply_daily.schema.json",
  "title": "supply_daily history file",
  "type": "object",
  "required": ["metric", "unit", "schema_version", "generated_at", "series"],
  "additionalProperties": false,
  "properties": {
    "metric": {"const": "supply_daily"},
    "unit": {"const": "BTC"},
    "schema_version": {"type": "integer", "const": 1},
    "generated_at": {"type": "string", "format": "date-time"},
    "series": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["date", "value", "source"],
        "additionalProperties": false,
        "properties": {
          "date": {"type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"},
          "value": {"type": "number", "minimum": 0, "maximum": 21000000},
          "source": {"type": "string", "enum": ["coinmetrics", "blockchain_info", "computed_subsidy_schedule"]},
          "carried_forward": {
            "type": "boolean",
            "description": "True only when this row's value was carried forward from the prior day after every source in the failover chain failed or was rejected this run -- not a fresh observation. Absent (or false) on every freshly-fetched row."
          }
        }
      }
    }
  }
}
