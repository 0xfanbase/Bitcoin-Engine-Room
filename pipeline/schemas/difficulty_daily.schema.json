{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fandamentals.github.io/bitcoin-engine-room/schemas/difficulty_daily.schema.json",
  "title": "difficulty_daily history file",
  "description": "Difficulty only changes at retarget boundaries (~every 2016 blocks). This series is a sparse step function: one row per retarget change, not one row per calendar day.",
  "type": "object",
  "required": ["metric", "unit", "schema_version", "generated_at", "series"],
  "additionalProperties": false,
  "properties": {
    "metric": {"const": "difficulty_daily"},
    "unit": {"const": "raw_difficulty"},
    "schema_version": {"type": "integer", "const": 1},
    "generated_at": {"type": "string", "format": "date-time"},
    "series": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["date", "value", "source"],
        "additionalProperties": false,
        "properties": {
          "date": {"type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"},
          "value": {"type": "number", "exclusiveMinimum": 0},
          "source": {"type": "string", "enum": ["blockchain_info"]}
        }
      }
    }
  }
}
